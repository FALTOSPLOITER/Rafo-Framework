# Rafo-Framework environment variables
# Copy this file to .env and fill in your own API keys.
# .env is excluded from git — never commit real keys.

SHODAN_API_KEY=your_shodan_api_key_here
IPINFO_API_KEY=your_ipinfo_api_key_here

# Optional: set a default wireless interface (e.g. wlan0)
DEFAULT_WIRELESS_INTERFACE=
